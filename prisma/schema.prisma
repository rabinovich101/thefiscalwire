generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Author {
  id        String    @id @default(uuid())
  name      String
  avatar    String?
  bio       String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  articles  Article[]
}

model Category {
  id               String           @id @default(uuid())
  name             String
  slug             String           @unique
  color            String           @default("bg-gray-600")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  type             CategoryType?
  businessArticles Article[]        @relation("BusinessCategory")
  primaryArticles  Article[]        @relation("PrimaryCategory")
  marketsArticles  Article[]        @relation("MarketsCategory")
  pageDefinitions  PageDefinition[]
  articles         Article[]        @relation("ArticleCategories")
}

model Tag {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  articles  Article[] @relation("ArticleToTag")
}

model Article {
  id                 String               @id @default(uuid())
  slug               String               @unique
  title              String
  excerpt            String
  content            Json
  imageUrl           String
  publishedAt        DateTime             @default(now())
  readTime           Int
  isFeatured         Boolean              @default(false)
  isBreaking         Boolean              @default(false)
  headings           Json?
  relevantTickers    String[]             @default([])
  authorId           String
  categoryId         String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  externalId         String?              @unique
  sourceUrl          String?
  isAiEnhanced       Boolean              @default(false)
  metaDescription    String?
  seoKeywords        String[]             @default([])
  businessCategoryId String
  marketsCategoryId  String
  author             Author               @relation(fields: [authorId], references: [id])
  businessCategory   Category             @relation("BusinessCategory", fields: [businessCategoryId], references: [id])
  category           Category?            @relation("PrimaryCategory", fields: [categoryId], references: [id])
  marketsCategory    Category             @relation("MarketsCategory", fields: [marketsCategoryId], references: [id])
  analysis           ArticleAnalysis?
  ArticleTranslation ArticleTranslation[]
  placements         ContentPlacement[]
  categories         Category[]           @relation("ArticleCategories")
  tags               Tag[]                @relation("ArticleToTag")
  Article_A          Article[]            @relation("RelatedArticles")
  Article_B          Article[]            @relation("RelatedArticles")

  @@index([slug])
  @@index([categoryId])
  @@index([marketsCategoryId])
  @@index([businessCategoryId])
  @@index([authorId])
  @@index([publishedAt])
}

model MarketIndex {
  id            String   @id @default(uuid())
  symbol        String   @unique
  name          String
  price         Float
  change        Float
  changePercent Float
  updatedAt     DateTime @updatedAt
}

model Video {
  id         String             @id @default(uuid())
  title      String
  thumbnail  String
  duration   String
  category   String
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  embedType  String?
  url        String?
  videoId    String?
  placements ContentPlacement[]
}

model BreakingNews {
  id       String  @id @default(uuid())
  isActive Boolean @default(true)
  headline String
  url      String
}

model User {
  id                String             @id @default(uuid())
  name              String?
  email             String             @unique
  emailVerified     DateTime?
  password          String?
  image             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  role              Role               @default(USER)
  dateOfBirth       DateTime?
  firstName         String?
  lastName          String?
  phoneNumber       String?
  username          String?            @unique
  accounts          Account[]
  contentPlacements ContentPlacement[]
  sessions          Session[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ActivityLog {
  id           String         @id @default(uuid())
  type         ActivityType
  action       String
  details      Json?
  count        Int?
  status       ActivityStatus
  errorMessage String?
  createdAt    DateTime       @default(now())

  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model ArticleAnalysis {
  id               String   @id @default(uuid())
  articleId        String   @unique
  markets          String[] @default([])
  primarySector    String?
  secondarySectors String[] @default([])
  subSectors       String[] @default([])
  industries       String[] @default([])
  primaryStock     String?
  mentionedStocks  String[] @default([])
  competitors      Json?
  businessType     String?
  sentiment        String?
  impactLevel      String?
  aiModel          String
  confidence       Float?
  rawResponse      Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  article          Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([primarySector])
  @@index([primaryStock])
  @@index([sentiment])
  @@index([businessType])
}

model PageDefinition {
  id          String          @id @default(uuid())
  name        String
  slug        String          @unique
  pageType    PageType
  categoryId  String?
  stockSymbol String?
  layoutId    String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  category    Category?       @relation(fields: [categoryId], references: [id])
  layout      LayoutTemplate? @relation(fields: [layoutId], references: [id])
  zones       PageZone[]

  @@index([pageType])
  @@index([slug])
}

model LayoutTemplate {
  id          String           @id @default(uuid())
  name        String
  description String?
  gridConfig  Json
  thumbnail   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  pages       PageDefinition[]
  zones       ZoneDefinition[]
}

model ZoneDefinition {
  id           String          @id @default(uuid())
  name         String
  slug         String          @unique
  description  String?
  zoneType     ZoneType
  gridArea     String?
  minItems     Int             @default(1)
  maxItems     Int             @default(10)
  defaultRules Json?
  layoutId     String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  pageZones    PageZone[]
  layout       LayoutTemplate? @relation(fields: [layoutId], references: [id])
}

model PageZone {
  id               String             @id @default(uuid())
  pageId           String
  zoneDefinitionId String
  customName       String?
  isEnabled        Boolean            @default(true)
  sortOrder        Int                @default(0)
  autoFillRules    Json?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  placements       ContentPlacement[]
  page             PageDefinition     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  zoneDefinition   ZoneDefinition     @relation(fields: [zoneDefinitionId], references: [id])

  @@unique([pageId, zoneDefinitionId])
  @@index([pageId])
}

model ContentPlacement {
  id            String      @id @default(uuid())
  zoneId        String
  contentType   ContentType
  articleId     String?
  videoId       String?
  customContent Json?
  position      Int         @default(0)
  isPinned      Boolean     @default(false)
  startDate     DateTime?
  endDate       DateTime?
  createdById   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  article       Article?    @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdBy     User?       @relation(fields: [createdById], references: [id])
  video         Video?      @relation(fields: [videoId], references: [id], onDelete: Cascade)
  zone          PageZone    @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@unique([zoneId, position])
  @@index([zoneId])
  @@index([articleId])
}

model AutoFillRule {
  id          String   @id @default(uuid())
  name        String
  description String?
  config      Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ArticleTranslation {
  id        String   @id
  articleId String
  locale    String
  title     String
  excerpt   String
  content   Json
  headings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime
  Article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, locale])
  @@index([articleId])
  @@index([locale])
}

enum CategoryType {
  MARKETS
  BUSINESS
}

enum Role {
  USER
  ADMIN
}

enum ActivityType {
  IMPORT
  PERPLEXITY_API
  NEWS_API
  ARTICLE_ANALYSIS
  ERROR
  SYSTEM
}

enum ActivityStatus {
  SUCCESS
  ERROR
  WARNING
  INFO
}

enum PageType {
  HOMEPAGE
  CATEGORY
  STOCK
  CUSTOM
  STATIC
  MARKETS
}

enum ZoneType {
  HERO_FEATURED
  HERO_SECONDARY
  ARTICLE_GRID
  ARTICLE_LIST
  TRENDING_SIDEBAR
  BREAKING_BANNER
  MARKET_TICKER
  MARKET_MOVERS
  VIDEO_CAROUSEL
  CATEGORY_NAV
  CUSTOM_HTML
  STOCK_CHART
  STOCK_NEWS
}

enum ContentType {
  ARTICLE
  VIDEO
  CUSTOM
  AUTO
}
